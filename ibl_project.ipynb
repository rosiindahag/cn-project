    "import os\n",
    "import re\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from iblatlas.regions import BrainRegions\n",
    "\n",
    "\n",
    "def get_modulated_mean_psth(reg, meta_stimon, pre_time, post_time, plot=False):\n",
    "    pre_time_idx = np.bitwise_and(meta_stimon['times'] >= pre_time[0], meta_stimon['times'] <= pre_time[1])\n",
    "    post_time_idx = np.bitwise_and(meta_stimon['times'] >= post_time[0], meta_stimon['times'] <= post_time[1])\n",
    "    psth, df = get_avg_psth_for_region(reg, meta_stimon)\n",
    "    df[\"pre\"] = np.mean(psth[:, pre_time_idx], axis=1)\n",
    "    df[\"post\"] = np.mean(psth[:, post_time_idx], axis=1)\n",
    "    df[\"modulation_idx\"] = (df[\"pre\"] - df[\"post\"]).abs() / (df[\"pre\"] + df[\"post\"]).abs()\n",
    "\n",
    "    idx_mod = np.bitwise_and(df[\"modulation_idx\"] > 0.3, df[\"modulation_idx\"] < 1)\n",
    "    mean_trace = psth[idx_mod, :].mean(axis=0)\n",
    "\n",
    "    if plot:\n",
    "        print(f\"{idx_mod.sum()}/{len(idx_mod)} of clusters are modulated\")\n",
    "        fig, ax = plt.subplots(figsize=(10, 5))\n",
    "        ax.set_title(reg)\n",
    "        ax.plot(meta[\"times\"], psth[idx_mod, :].T, c=\"grey\")\n",
    "        ax.plot(meta[\"times\"], mean_trace, c=\"k\", lw=2)\n",
    "        ax.axvline(x=0, color=\"red\", linestyle=\"--\")\n",
    "        ax.set_xlabel(\"Time from stim on (s)\")\n",
    "        ax.set_ylabel(\"Firing rate (Hz)\")\n",
    "        plt.show()\n",
    "\n",
    "    return mean_trace\n",
    "\n",
    "def get_region_psth(region, meta_stimon, pre_time=[-0.3, -0.05], post_time=[0.05, 0.1], plot=False):\n",
    "    filtered_clusters = meta_stimon.clusters[\n",
    "        meta_stimon.clusters[\"acronym_allen\"].str.contains(region, na=False)\n",
    "    ]\n",
    "    regs = filtered_clusters[\"acronym\"].unique()\n",
    "\n",
    "    all_meanpsth = [\n",
    "        get_modulated_mean_psth(reg, meta_stimon, pre_time, post_time, plot=plot) for reg in regs\n",
    "    ]\n",
    "    return all_meanpsth\n",
    "\n",
    "\n",
    "def build_region_data(meta_stimon, cache_path=\"region_data_dict.csv\", force_recompute=False):\n",
    "    if not force_recompute and os.path.exists(cache_path):\n",
    "        df_avg = pd.read_csv(cache_path)\n",
    "        df_avg[\"avg\"] = df_avg[\"avg\"].apply(extract_numbers_from_string)\n",
    "        return df_avg\n",
    "\n",
    "    regions_allen = meta_stimon.clusters[\"acronym_allen\"].unique()\n",
    "\n",
    "    region_data_dict = {\n",
    "        reg: get_region_psth(reg, meta_stimon) for reg in regions_allen\n",
    "    }\n",
    "\n",
    "    br = BrainRegions()\n",
    "    beryl_regions = {}\n",
    "    for reg_allen in regions_allen:\n",
    "        acr = br.acronym2acronym(reg_allen, mapping=\"Beryl\")\n",
    "        beryl_key = reg_allen if acr[0] == \"root\" else acr[0]\n",
    "        beryl_regions.setdefault(beryl_key, []).append(reg_allen)\n",
    "\n",
    "    allen_to_beryl = {\n",
    "        allen: beryl\n",
    "        for beryl, allen_list in beryl_regions.items()\n",
    "        for allen in allen_list\n",
    "    }\n",
    "\n",
    "    allen_regions = list(region_data_dict.keys())\n",
    "    df_avg = pd.DataFrame({\n",
    "        \"region\": allen_regions,\n",
    "        \"avg\": list(region_data_dict.values()),\n",
    "        \"beryl_region\": [allen_to_beryl.get(reg, reg) for reg in allen_regions],\n",
    "    })\n",
    "\n",
    "    df_avg.to_csv(cache_path, index=False)\n",
    "\n",
    "    return df_avg\n",
    "\n",
    "\n",
    "def extract_numbers_from_string(text_str):\n",
    "    if pd.isna(text_str):\n",
    "        return []\n",
    "    found_nums = re.findall(r\"[-+]?\\d*\\.\\d+|\\d+\", str(text_str))\n",
    "    return [float(n) for n in found_nums]\n",
    "\n",
    "\n",
    "def elementwise_mean(series_of_lists):\n",
    "    grid = pd.DataFrame(series_of_lists.tolist())\n",
    "    return grid.mean(axis=0).tolist()\n",
    "\n",
    "\n",
    "def group_by_beryl(df_avg):\n",
    "    df_new = (\n",
    "        df_avg.groupby(\"beryl_region\")\n",
    "        .agg({\"avg\": elementwise_mean, \"region\": list})\n",
    "        .reset_index()\n",
    "        .rename(columns={\"avg\": \"new_avg\", \"region\": \"allen_region\"})\n",
    "    )\n",
    "    return df_new\n",
    "\n",
    "\n",
    "def plot_all_beryl_regions(df_new, meta_stimon, activity_threshold=30):\n",
    "    time_axis = meta_stimon[\"times\"][:150]\n",
    "    expected_length = len(time_axis)\n",
    "\n",
    "    active_regions_count = sum(\n",
    "        1\n",
    "        for _, row in df_new.iterrows()\n",
    "        if row[\"new_avg\"] is not None\n",
    "        and len(row[\"new_avg\"]) >= expected_length\n",
    "        and max(row[\"new_avg\"][:expected_length]) > activity_threshold\n",
    "    )\n",
    "\n",
    "    color_palette = plt.get_cmap(\"turbo\").resampled(max(1, active_regions_count))\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(12, 6))\n",
    "    color_idx = 0\n",
    "\n",
    "    for _, row in df_new.iterrows():\n",
    "        region_name = row[\"beryl_region\"]\n",
    "        grand_mean = row[\"new_avg\"]\n",
    "\n",
    "        if grand_mean is None or len(grand_mean) < expected_length:\n",
    "            continue\n",
    "\n",
    "        grand_mean = grand_mean[:expected_length]\n",
    "\n",
    "        if max(grand_mean) > activity_threshold:\n",
    "            line_label = region_name\n",
    "            line_color = color_palette(color_idx)\n",
    "            line_width = 2.5\n",
    "            line_alpha = 1.0\n",
    "            line_zorder = 5\n",
    "            color_idx += 1\n",
    "        else:\n",
    "            line_label = \"_nolegend_\"\n",
    "            line_color = \"lightgray\"\n",
    "            line_width = 1.0\n",
    "            line_alpha = 0.4\n",
    "            line_zorder = 2\n",
    "\n",
    "        ax.plot(\n",
    "            time_axis,\n",
    "            grand_mean,\n",
    "            color=line_color,\n",
    "            lw=line_width,\n",
    "            alpha=line_alpha,\n",
    "            zorder=line_zorder,\n",
    "            label=line_label,\n",
    "        )\n",
    "\n",
    "    ax.axvline(x=0, color=\"black\", linestyle=\"--\", alpha=0.7, label=\"Stimulus Onset\")\n",
    "    ax.set_xlabel(\"Time (s)\", fontsize=12)\n",
    "    ax.set_ylabel(\"Firing rate (Hz)\", fontsize=12)\n",
    "    ax.set_title(\n",
    "        \"Average of Neural Population Activity Across Beryl Regions \"\n",
    "        f\"(>{activity_threshold} Hz Highlighted)\",\n",
    "        fontsize=14,\n",
    "        fontweight=\"bold\",\n",
    "    )\n",
    "    ax.legend(bbox_to_anchor=(1.05, 1), loc=\"upper left\", fontsize=9, ncol=2)\n",
    "    plt.grid(axis=\"both\", linestyle=\":\", alpha=0.5)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "def plot_group_comparison(meta_stimon, all_meanpsth_ss, all_meanpsth_vis, all_meanpsth_hpf):\n",
    "    matrix_ss = np.asarray(all_meanpsth_ss)\n",
    "    matrix_vis = np.asarray(all_meanpsth_vis)\n",
    "    matrix_hpf = np.asarray(all_meanpsth_hpf)\n",
    "\n",
    "    time_axis = meta_stimon[\"times\"][:150]\n",
    "\n",
    "    grand_mean_ss = np.mean(matrix_ss, axis=0)\n",
    "    grand_mean_vis = np.mean(matrix_vis, axis=0)\n",
    "    grand_mean_hpf = np.mean(matrix_hpf, axis=0)\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(10, 5))\n",
    "    ax.plot(time_axis, grand_mean_ss, color=\"royalblue\", lw=3, label=\"Somatosensory Cortex (SS)\")\n",
    "    ax.plot(time_axis, grand_mean_vis, color=\"crimson\", lw=3, label=\"Visual Cortex (VIS)\")\n",
    "    ax.plot(time_axis, grand_mean_hpf, color=\"green\", lw=3, label=\"Hippocampal\")\n",
    "\n",
    "    ax.axvline(x=0, color=\"black\", linestyle=\"--\", alpha=0.7, label=\"Stimulus Onset\")\n",
    "    ax.set_xlabel(\"Time (s)\", fontsize=12)\n",
    "    ax.set_ylabel(\"Firing rate (Hz)\", fontsize=12)\n",
    "    ax.set_title(\"Average of Neural Population Activity\", fontsize=14, fontweight=\"bold\")\n",
    "    ax.legend(loc=\"upper right\")\n",
    "    plt.grid(axis=\"both\", linestyle=\":\", alpha=0.5)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "def get_visual_sessions(meta_stimon):\n",
    "    filtered_clusters_vis = meta_stimon.clusters[\n",
    "        meta_stimon.clusters[\"acronym_allen\"].str.contains(\"VIS\", na=False)\n",
    "    ]\n",
    "    pid_vis = filtered_clusters_vis[\"pid\"].unique()\n",
    "    eid_vis = meta_stimon.sessions[\"eid\"][np.isin(meta_stimon.sessions[\"pid\"], pid_vis)]\n",
    "    return pid_vis, eid_vis\n",
    "\n",
    "\n",
    "def get_high_rate_clusters(meta_stimon, rate_threshold=100):\n",
    "    pre = meta_stimon.clusters[\n",
    "        (meta_stimon.clusters[\"psth_index\"] <= 49) & (meta_stimon.clusters[\"psth_index\"] > 40)\n",
    "    ]\n",
    "    post = meta_stimon.clusters[\n",
    "        (meta_stimon.clusters[\"psth_index\"] >= 50) & (meta_stimon.clusters[\"psth_index\"] < 60)\n",
    "    ]\n",
    "\n",
    "    pre_high_rate = pre[pre[\"firing_rate\"] >= rate_threshold]\n",
    "    post_high_rate = post[post[\"firing_rate\"] >= rate_threshold]\n",
    "    return pre_high_rate, post_high_rate\n",
    "\n",
    "pid_vis, eid_vis = get_visual_sessions(meta_stimon)\n",
    "pre_high_rate, post_high_rate = get_high_rate_clusters(meta_stimon)\n",
    "\n",
    "pre_time = [-0.3, -0.05]\n",
    "post_time = [0.05, 0.1]\n",
    "\n",
    "df_avg = build_region_data(meta_stimon)\n",
    "df_new = group_by_beryl(df_avg)\n",
    "print(df_new)\n",
    "\n",
    "plot_all_beryl_regions(df_new, meta_stimon)\n",
    "all_meanpsth_ss = get_region_psth(\"SS\", meta_stimon, pre_time, post_time)\n",
    "all_meanpsth_vis = get_region_psth(\"VIS\", meta_stimon, pre_time, post_time)\n",
    "all_meanpsth_hpf = get_region_psth(\"HPF\", meta_stimon, pre_time, post_time)\n",
    "\n",
    "plot_group_comparison(meta_stimon, all_meanpsth_ss, all_meanpsth_vis, all_meanpsth_hpf)"
   ]
